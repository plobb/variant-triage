nextflow.enable.dsl = 2

params {
    input           = "data/*.vcf.gz"
    outdir          = "results"
    skip_annotation = false
}

process {
    cpus   = 2
    memory = '4.GB'
    time   = '2.h'
}

docker {
    enabled    = true
    runOptions = '-u $(id -u):$(id -g)'
}

profiles {
    standard {
        docker.enabled = true
    }

    demo {
        // Skips VEP annotation — no cache required
        params.skip_annotation = true
    }

    ci {
        // Nextflow is not executed in CI — pipeline files are lint-checked only
        docker.enabled = false
    }
}
