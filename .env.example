# Copy to .env and fill in real values before running locally.
# NEVER commit .env to version control.

# Database
DB_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/variant_triage

# Security — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-secure-random-hex-string

# Logging: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# deployment stage: development | staging | production
ENVIRONMENT=development

# JWT
ACCESS_TOKEN_EXPIRE_MINUTES=30
ALGORITHM=HS256
